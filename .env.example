# ===========================
# App
# ===========================
NODE_ENV=development
PORT=3000
API_PREFIX=api

# ===========================
# Database (Neon PostgreSQL)
# ===========================
DATABASE_URL=

# ===========================
# JWT
# ===========================
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# ===========================
# Redis
# ===========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================
# Rate limiting
# ===========================
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ===========================
# Storage (S3)
# ===========================
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ===========================
# Payment (VNPay)
# ===========================
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/api/v1/payments/vnpay-return

# ===========================
# Mail
# ===========================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@yourapp.com

# ===========================
# Zalo OA
# ===========================
ZALO_OA_TOKEN=
ZALO_OA_SECRET=

# ===========================
# Loyalty
# ===========================
DEFAULT_LOYAL_POINT_PER_UNIT=1
DEFAULT_TAX_PERCENTAGE=10